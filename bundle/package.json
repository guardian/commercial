{
	"name": "@guardian/commercial-bundle",
	"version": "0.0.0",
	"description": "Guardian advertising business logic",
	"homepage": "https://github.com/guardian/commercial#readme",
	"bugs": {
		"url": "https://github.com/guardian/commercial/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/guardian/commercial.git"
	},
	"private": true,
	"license": "Apache-2.0",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "pnpm run --parallel --aggregate-output /^build:.*/",
		"build:dev": "webpack -c webpack.config.dev.mjs",
		"build:prod": "webpack -c webpack.config.prod.mjs",
		"clean": "rm -rf dist",
		"playwright:run": "playwright test",
		"playwright:open": "playwright test --ui",
		"lint": "eslint .",
		"lint-staged": "lint-staged",
		"prepare": "husky",
		"prettier:check": "prettier . --check --cache",
		"prettier:fix": "prettier . --write --cache",
		"serve": "OVERRIDE_BUNDLE=true pnpm webpack-dev-server -c ./webpack.config.dev.mjs",
		"test": "jest",
		"test-cov": "jest --coverage",
		"tsc": "tsc --noEmit"
	},
	"devDependencies": {
		"@babel/cli": "7.28.6",
		"@babel/core": "7.29.0",
		"@babel/plugin-syntax-dynamic-import": "7.8.3",
		"@babel/plugin-transform-runtime": "7.29.0",
		"@babel/preset-env": "7.29.2",
		"@babel/preset-react": "7.28.5",
		"@changesets/cli": "2.30.0",
		"@guardian/browserslist-config": "7.0.0",
		"@guardian/commercial-core": "workspace:*",
		"@guardian/core-web-vitals": "19.0.0",
		"@guardian/identity-auth": "15.0.0",
		"@guardian/identity-auth-frontend": "17.0.0",
		"@guardian/libs": "31.0.0",
		"@guardian/ophan-tracker-js": "2.8.0",
		"@guardian/source": "12.2.1",
		"@playwright/test": "1.59.1",
		"@types/google-publisher-tag": "1.20260330.0",
		"@types/jest": "30.0.0",
		"@types/lodash-es": "4.17.12",
		"@types/node": "25.5.2",
		"@types/webpack-env": "1.18.8",
		"babel-jest": "30.3.0",
		"babel-loader": "10.1.1",
		"babel-plugin-dynamic-import-node": "2.3.3",
		"circular-dependency-plugin": "5.2.2",
		"fastdom": "1.0.12",
		"globals": "17.5.0",
		"html-webpack-plugin": "5.6.7",
		"husky": "9.1.7",
		"jest": "30.3.0",
		"jest-environment-jsdom": "30.3.0",
		"jest-environment-jsdom-global": "4.0.0",
		"lint-staged": "16.4.0",
		"lodash-es": "4.18.1",
		"npm-run-all": "4.1.5",
		"prebid.js": "10.23.0",
		"process": "0.11.10",
		"raw-loader": "4.0.2",
		"terser-webpack-plugin": "5.4.0",
		"ts-jest": "29.4.9",
		"ts-loader": "9.5.4",
		"type-fest": "5.5.0",
		"typescript": "6.0.2",
		"webpack": "5.106.1",
		"webpack-bundle-analyzer": "5.3.0",
		"webpack-cli": "7.0.2",
		"webpack-dev-server": "5.2.3",
		"webpack-merge": "6.0.1",
		"web-vitals": "5.2.0"
	},
	"prettier": "@guardian/prettier",
	"publishConfig": {
		"access": "public"
	},
	"browserslist": [
		"extends @guardian/browserslist-config"
	]
}
