{
	"compilerOptions": {
		"rootDir": "src",
		"paths": {
			// We have to point to the prebid dist files here because the source files
			// don't have type definitions, but the dist files do. Ensure these paths
			// are in sync with the paths in the webpack config aliases or they'll pass
			// in type checking but fail the build
			"prebid.js/dist/*": ["./node_modules/prebid.js/dist/src/*"]
		},
		"types": ["node", "jest", "google-publisher-tag"]
	},
	"extends": "../tsconfig.json",
	"include": ["./src/**/*.ts"],
	"exclude": ["node_modules", "dist"]
}
